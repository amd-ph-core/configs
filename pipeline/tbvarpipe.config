/*
 * ---------------------------------------------------------
 *  amd-ph-core/tbvarpipe pipeline configuration
 * ---------------------------------------------------------
 *
 * Auto-loaded by the pipeline via custom_config_base.
 * Includes all pipeline-specific params, container overrides,
 * resource tuning, and AMDP resource labels.
 *
 * See conf/pipeline/tbvarpipe/README.md for usage.
 */

includeConfig "${params.custom_config_base}/conf/pipeline/tbvarpipe/params.config"
includeConfig "${params.custom_config_base}/conf/pipeline/tbvarpipe/containers.config"
includeConfig "${params.custom_config_base}/conf/pipeline/tbvarpipe/modules.config"
includeConfig "${params.custom_config_base}/conf/pipeline/tbvarpipe/resource_labels.config"
