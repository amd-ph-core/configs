/*
 * ---------------------------------------------------------
 *  AMDP Dev environment overlay for amd-ph-core pipelines
 * ---------------------------------------------------------
 *
 * Internal-only settings that external users cannot replicate:
 *   - AWS Batch executor and job queue
 *   - ECR container registry
 *   - S3 static asset paths
 *
 * Usage:
 *   nextflow run amd-ph-core/tbvarpipe -r 1.2.0 \
 *     -profile docker,amd \
 *     -c conf/amdp/amdp-dev.config \
 *     --input samplesheet.csv --outdir s3://bucket/results
 */

// ---------------------------------------------------------------------------
// AWS Batch execution
// ---------------------------------------------------------------------------
aws {
    batch {
        cliPath          = '/home/ec2-user/miniconda/bin/aws'
        maxSpotAttempts  = 3
    }
    region = 'us-east-1'
}

process {
    executor       = 'awsbatch'
    queue          = 'amdp-dev-batch-ec2-job-queue'
    maxRetries     = 3
    errorStrategy  = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }

    resourceLimits = [
        cpus:   96,
        memory: '768.GB',
        time:   '24.h',
    ]
}

// ---------------------------------------------------------------------------
// Container registry (internal ECR)
// ---------------------------------------------------------------------------
docker.registry  = '025066257930.dkr.ecr.us-east-1.amazonaws.com'
podman.registry  = '025066257930.dkr.ecr.us-east-1.amazonaws.com'
wave.enabled     = false
fusion.enabled   = false

// ---------------------------------------------------------------------------
// Static assets (S3)
// ---------------------------------------------------------------------------
params {
    static_assets = 's3://amdp-dev-static-assets/amd-ph-core-static-assets'
}
