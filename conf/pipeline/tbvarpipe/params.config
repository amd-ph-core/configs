/*
 * ---------------------------------------------------------
 *  amd-ph-core/tbvarpipe pipeline parameters
 * ---------------------------------------------------------
 *
 * Static asset path resolution. When static_assets is set
 * (via --static_assets or an environment overlay config),
 * all reference file paths resolve automatically.
 */

params {
    // Static asset paths
    static_assets              = null

    // Clockwork decontamination references
    clockwork_ref_preprocessing  = params.static_assets ? "${params.static_assets}/clockwork/cdc-tb/ref_preprocessing.fa" : null
    clockwork_meta_preprocessing = params.static_assets ? "${params.static_assets}/clockwork/cdc-tb/remove_contam_metadata_preprocessing.tsv" : null

    // Varpipe-WGS reference and annotation files
    ref_fasta    = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/ref2.fa" : null
    reported     = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/reportable.txt" : null
    included     = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/intervals.bed" : null
    bedlist_amp  = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/amp_bed.txt" : null
    bedlist_one  = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/bed_1.txt" : null
    bedlist_two  = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/bed_2.txt" : null
    bedstruct    = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/BED.txt" : null
    mutationloci = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/mutation_loci.txt" : null
    lineages     = params.static_assets ? "${params.static_assets}/tbvarpipe/1.0.0/lineage_markers.txt" : null
    snpeff_cache = params.static_assets ? "${params.static_assets}/snpeff/5.0/tb/data" : null
    snpeff_db    = 'mtb_NC_000962_3'
}
